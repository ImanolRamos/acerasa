{
  "__inputs": [{ "name": "DS_TIMESCALEDB", "label": "TimescaleDB", "type": "datasource", "pluginId": "postgres" }],
  "title": "Koiote — MQTT Messages",
  "uid": "koiote-mqtt",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total mensajes recibidos",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": { "colorMode": "value", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
        "rawSql": "SELECT NOW() AS time, COUNT(*) AS value FROM mqtt_messages WHERE $__timeFilter(time)",
        "format": "table"
      }]
    },
    {
      "id": 2,
      "title": "Topics activos",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": { "colorMode": "value", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
        "rawSql": "SELECT NOW() AS time, COUNT(DISTINCT topic) AS value FROM mqtt_messages WHERE $__timeFilter(time)",
        "format": "table"
      }]
    },
    {
      "id": 3,
      "title": "Último mensaje recibido",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 8, "y": 0 },
      "options": { "colorMode": "value", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "dateTimeFromNow" } },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
        "rawSql": "SELECT NOW() AS time, EXTRACT(EPOCH FROM NOW() - MAX(time AT TIME ZONE 'UTC')) * 1000 AS value FROM mqtt_messages",
        "format": "table"
      }]
    },
    {
      "id": 4,
      "title": "Últimos valores por topic",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "options": { "sortBy": [{ "displayName": "Tiempo", "desc": true }] },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
        "rawSql": "SELECT time AS \"Tiempo\", topic AS \"Topic\", payload::text AS \"Payload\", raw AS \"Raw\" FROM mqtt_latest ORDER BY time DESC",
        "format": "table"
      }]
    },
    {
      "id": 5,
      "title": "Mensajes por minuto",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "min": 0 }
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
        "rawSql": "SELECT time_bucket('1 minute', time) AS time, topic, COUNT(*) AS value FROM mqtt_messages WHERE $__timeFilter(time) GROUP BY time_bucket('1 minute', time), topic ORDER BY 1",
        "format": "time_series"
      }]
    },
    {
      "id": 6,
      "title": "Historial de mensajes",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "options": { "sortBy": [{ "displayName": "Tiempo", "desc": true }] },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
        "rawSql": "SELECT time AS \"Tiempo\", topic AS \"Topic\", payload::text AS \"Payload\" FROM mqtt_messages WHERE $__timeFilter(time) ORDER BY time DESC LIMIT 100",
        "format": "table"
      }]
    }
  ]
}
